[user]
	name = Pulkit Maloo
	email = pmaloo@amazon.com
[core]
	excludesfile = ~/.gitignore
	editor = vim
	pager = delta
[merge]
	tool = vimdiff
	conflictstyle = diff3
[rebase]
	autosquash = true
[branch]
	autosetuprebase = always
[pull]
	rebase = true
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
