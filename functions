# Create a new directory and enter it
function mkd() {
    mkdir -p "$@" && cd "$_";
}

# `o` with no arguments opens the current directory, otherwise opens the given location
function o() {
    local opener
    if [[ "$OSTYPE" == darwin* ]]; then
        opener="open"
    else
        opener="xdg-open"
    fi
    if [ $# -eq 0 ]; then
        $opener .;
    else
        $opener "$@";
    fi;
}
