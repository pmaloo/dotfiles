# Amazon-specific configuration
# Remove this file (or unlink ~/.work) when leaving Amazon.
# Everything else in dotfiles remains portable.

# --- Aliases ---
alias bb='brazil-build'
alias bba='brazil-build apollo-pkg'
alias bre='brazil-runtime-exec'
alias brc='brazil-recursive-cmd'
alias bws='brazil ws'
alias bwsuse='bws use -p'
alias bwscreate='bws create -n'
alias bbr='brc brazil-build'
alias bball='brc --allPackages'
alias bbb='brc --allPackages brazil-build'
alias bbra='bbr apollo-pkg'

alias mw='mwinit -o'
alias cds='ssh clouddesk'
alias mc='meshclaw-open'

# --- Functions ---

# Quick brazil build with summary
bbq() {
    brazil-build release > /tmp/bb.log 2>&1 && echo "BUILD PASSED" || (tail -20 /tmp/bb.log && return 1)
}

# Port forward to cloud desktop
cdport() {
    ssh -L "$1":localhost:"$1" clouddesk -N
}

# --- Paths ---
export PATH="$HOME/.toolbox/bin:$HOME/.aim/mcp-servers:$PATH"

# --- AWS ---
export AWS_PROFILE=notebook

# --- Environment ---
# Set CLOUD_DESKTOP in ~/.local-env (not tracked by git)
# echo 'export CLOUD_DESKTOP="dev-dsk-yourhost.us-west-2.amazon.com"' > ~/.local-env
[ -f ~/.local-env ] && source ~/.local-env
